const allSites = Object.values(siteCategories).flat();
let checkingFreenet = false;
let checkingDirect = false;
let autoRefreshEnabled = true;
let autoCheckTimer = null;
let currentGraphUrl = null;
let currentGraphName = null;

let latencyChart = null;
const latencyHistory = {
    labels: [],
    direct: [],
    directStatus: [],
    freenet: [],
    freenetStatus: []
};

function initLatencyChart() {
    const ctx = document.getElementById('latencyChart').getContext('2d');
    latencyChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: latencyHistory.labels,
            datasets: [
                {
                    label: 'Direct Access (ms)',
                    data: latencyHistory.direct,
                    borderColor: '#ff4d4d',
                    backgroundColor: 'rgba(255, 77, 77, 0.1)',
                    borderWidth: 2,
                    tension: 0.3,
                    fill: false,
                    pointBackgroundColor: '#ff4d4d',
                    pointStyle: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 'crossRot' : 'circle'),
                    pointRadius: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 8 : 4),
                    pointHoverRadius: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 10 : 6),
                    segment: {
                        borderColor: ctx => latencyHistory.directStatus[ctx.p1DataIndex] || latencyHistory.directStatus[ctx.p0DataIndex] ? 'rgba(255, 77, 77, 0.5)' : undefined,
                        borderDash: ctx => latencyHistory.directStatus[ctx.p1DataIndex] || latencyHistory.directStatus[ctx.p0DataIndex] ? [5, 5] : undefined,
                    }
                },
                {
                    label: 'FreeNet Access (ms)',
                    data: latencyHistory.freenet,
                    borderColor: '#64ffda',
                    backgroundColor: 'rgba(100, 255, 218, 0.1)',
                    borderWidth: 3,
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: '#64ffda',
                    pointStyle: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 'crossRot' : 'circle'),
                    pointRadius: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 8 : 4),
                    pointHoverRadius: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 10 : 6),
                    segment: {
                        borderDash: ctx => latencyHistory.freenetStatus[ctx.p1DataIndex] || latencyHistory.freenetStatus[ctx.p0DataIndex] ? [5, 5] : undefined,
                    }
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: '#8892b0', font: { family: 'JetBrains Mono', size: 10 } }
                },
                y: {
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: '#8892b0', font: { family: 'JetBrains Mono', size: 10 } },
                    beginAtZero: true,
                    title: { display: true, text: 'Latency (ms)', color: '#8892b0', font: { family: 'Outfit' } }
                }
            },
            plugins: {
                legend: {
                    display: true,
                    position: 'top',
                    labels: { color: '#e6f1ff', font: { family: 'Outfit', size: 12 }, usePointStyle: true }
                },
                tooltip: {
                    backgroundColor: '#112240',
                    titleColor: '#64ffda',
                    bodyColor: '#e6f1ff',
                    borderColor: '#233554',
                    borderWidth: 1,
                    padding: 12,
                    titleFont: { family: 'Outfit', weight: 'bold', size: 14 },
                    bodyFont: { family: 'JetBrains Mono' },
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            const isFreenet = label.includes('FreeNet');
                            const isBlocked = isFreenet ? latencyHistory.freenetStatus[context.dataIndex] : latencyHistory.directStatus[context.dataIndex];
                            if (label) label += ': ';
                            if (isBlocked) {
                                return label + '❌ BLOCKED';
                            }
                            return label + context.raw + 'ms';
                        }
                    }
                }
            }
        }
    });
}

function toggleLanguage() {
    currentLang = currentLang === "en" ? "ru" : "en";
    const t = translations[currentLang];
    
    document.getElementById("pageTitle").textContent = getTitleWithDate(t.title);
    document.getElementById("btnDirect").textContent = t.refreshDirect;
    document.getElementById("btnVPN").textContent = t.testFreenet;
    document.getElementById("langToggle").textContent = t.lang;
    document.getElementById("lblGlobalStatus").textContent = t.globalStatus;
    document.getElementById("lblAccessible").textContent = t.directlyAccessible;
    document.getElementById("lblFreenetReady").textContent = t.freenetWorking;
    
    // Search elements
    document.getElementById("lblSearchTitle").innerHTML = '<i data-lucide="search" style="width: 18px; margin-top: -2px"></i> ' + t.searchTitle;
    document.getElementById("customUrl").placeholder = t.searchPlaceholder;
    document.getElementById("btnCustom").textContent = t.searchBtn;
    document.getElementById("lblResDirect").textContent = t.resDirect;
    document.getElementById("lblResVPN").textContent = t.resVPN;

    const cdVal = document.getElementById("customDirectVal");
    const cvVal = document.getElementById("customVPNVal");
    if (cdVal.getAttribute("data-status")) updateBadgeText(cdVal, cdVal.getAttribute("data-status"), t);
    if (cvVal.getAttribute("data-status")) updateBadgeText(cvVal, cvVal.getAttribute("data-status"), t);

    allSites.forEach(s => {
        const id = s.name.replace(/[^a-z0-9]/gi, "_");
        const db = document.getElementById(id + "_direct_val");
        const vb = document.getElementById(id + "_vpn_val");
        const dl = document.getElementById(id + "_direct_label");
        const vl = document.getElementById(id + "_vpn_label");
        
        if (dl) dl.textContent = t.direct + ":";
        if (vl) vl.textContent = t.freenet + ":";
        
        if (db) {
            const status = db.getAttribute("data-status");
            if (db.classList.contains("checking")) db.textContent = t.checking;
            else if (status !== null) updateBadgeText(db, status, t);
        }
        
        if (vb) {
            const status = vb.getAttribute("data-status");
            if (vb.classList.contains("checking")) vb.textContent = t.checking;
            else if (status !== null) updateBadgeText(vb, status, t);
        }
    });
    lucide.createIcons();
}

function updateBadgeText(el, status, t) {
    if (status === "1") {
        el.textContent = t.online;
        el.className = "badge-status online";
    } else if (status === "0") {
        el.textContent = t.offline;
        el.className = "badge-status offline";
    } else {
        el.textContent = "—";
        el.className = "badge-status";
    }
}

function getFavicon(site) {
    if (site.name === "WhatsApp") return "https://static.whatsapp.net/rsrc.php/v3/yP/r/r_oBsbi9V90.png";
    try {
        return "https://www.google.com/s2/favicons?sz=64&domain=" + new URL(site.url).hostname;
    } catch (e) {
        return "";
    }
}

function buildGrid() {
    const container = document.getElementById("monitorGrid");
    container.innerHTML = "";
    const t = translations[currentLang];

    for (const [cat, sites] of Object.entries(siteCategories)) {
        const title = document.createElement("h2");
        title.className = "category-title";
        title.textContent = cat;
        container.appendChild(title);

        const grid = document.createElement("div");
        grid.className = "grid";
        
        sites.forEach(site => {
            const id = site.name.replace(/[^a-z0-9]/gi, "_");
            const faviconUrl = getFavicon(site);
            const card = document.createElement("div");
            card.className = "card";
            card.style.cursor = "pointer";
            card.onclick = () => { startGraphForSite(site.url, site.name); };
            card.innerHTML = 
                "<div class=\"site-info\">" +
                    "<img src=\"" + faviconUrl + "\" class=\"site-icon\" onerror=\"this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2224%22 height=%2224%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364ffda%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><circle cx=%2212%22 cy=%2212%22 r=%2210%22></circle><line x1=%222%22 y1=%2212%22 x2=%2222%22 y2=%2212%22></line><path d=%22M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z%22></path></svg>'\">" +
                    "<span class=\"site-name\">" + site.name + "</span>" +
                "</div>" +
                "<div class=\"status-badges\">" +
                    "<div class=\"badge\" id=\"" + id + "_vpn_badge\">" +
                        "<span id=\"" + id + "_vpn_label\">" + t.freenet + ":</span>" +
                        "<span id=\"" + id + "_vpn_val\" class=\"badge-status\">—</span>" +
                    "</div>" +
                    "<div class=\"badge\" id=\"" + id + "_direct_badge\">" +
                        "<span id=\"" + id + "_direct_label\">" + t.direct + ":</span>" +
                        "<span id=\"" + id + "_direct_val\" class=\"badge-status\">—</span>" +
                    "</div>" +
                "</div>";
            grid.appendChild(card);
        });
        container.appendChild(grid);
    }
    if (typeof lucide !== 'undefined') lucide.createIcons();
}

async function fetchWithTimeout(resource, options = {}) {
    const { timeout = 3000 } = options;
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeout);
    try {
        const response = await fetch(resource, { ...options, signal: controller.signal });
        clearTimeout(id);
        return response;
    } catch (e) {
        clearTimeout(id);
        throw e;
    }
}

async function checkSite(site, useVpn) {
    const id = site.name.replace(/[^a-z0-9]/gi, "_");
    const suffix = useVpn ? "_vpn" : "_direct";
    const valEl = document.getElementById(id + suffix + "_val");
    const t = translations[currentLang];

    valEl.textContent = t.checking;
    valEl.className = "badge-status checking";

    try {
        const res = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(site.url) + "&use_vpn=" + useVpn);
        const data = await res.json();
        const status = data.status === "down" ? "0" : "1";
        valEl.setAttribute("data-status", status);
        updateBadgeText(valEl, status, t);
    } catch (e) {
        valEl.setAttribute("data-status", "0");
        updateBadgeText(valEl, "0", t);
    }
    updateStats();
}
async function startGraphForSite(url, name, isAuto = false) {
    if (!url) return;
    
    if (autoCheckTimer) clearTimeout(autoCheckTimer);

    if (!isAuto) {
        currentGraphUrl = url;
        currentGraphName = name;
        latencyHistory.labels = [];
        latencyHistory.direct = [];
        latencyHistory.directStatus = [];
        latencyHistory.freenet = [];
        latencyHistory.freenetStatus = [];
        if (latencyChart) {
            latencyChart.destroy();
            latencyChart = null;
        }
        document.getElementById('directPctBig').textContent = '--%';
        document.getElementById('freenetPctBig').textContent = '--%';
        
        const titleEl = document.getElementById('chartTitle');
        if(titleEl) titleEl.textContent = `Monitoring: ${name}`;
        
        const chartCont = document.getElementById('chartContainer');
        if(chartCont) chartCont.style.display = 'block';
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    try {
        const startTotal = Date.now();
        await Promise.all([
            (async () => {
                const s = Date.now();
                try {
                    const resV = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(url) + "&use_vpn=true");
                    const dataV = await resV.json();
                    const lat = Date.now() - s;
                    const statusV = dataV.status === "down" ? "0" : "1";
                    latencyHistory.freenet.push(lat);
                    latencyHistory.freenetStatus.push(statusV === "0");
                } catch (e) {
                    latencyHistory.freenet.push(3000); 
                    latencyHistory.freenetStatus.push(true);
                }
            })(),
            (async () => {
                const s = Date.now();
                try {
                    const resD = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(url) + "&use_vpn=false");
                    const dataD = await resD.json();
                    const lat = Date.now() - s;
                    const statusD = dataD.status === "down" ? "0" : "1";
                    latencyHistory.direct.push(lat);
                    latencyHistory.directStatus.push(statusD === "0");
                } catch (e) {
                    latencyHistory.direct.push(3000);
                    latencyHistory.directStatus.push(true);
                }
            })()
        ]);

        const host = new URL(url).hostname;
        latencyHistory.labels.push(new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'}));
        
        const MAX_SAMPLES = 20;
        if (latencyHistory.labels.length > MAX_SAMPLES) {
            latencyHistory.labels.shift();
            latencyHistory.direct.shift();
            latencyHistory.directStatus.shift();
            latencyHistory.freenet.shift();
            latencyHistory.freenetStatus.shift();
        }
        
        if (!latencyChart) {
            initLatencyChart();
        }

        const totalReqs = latencyHistory.labels.length;
        if (totalReqs > 0) {
            const dirFails = latencyHistory.directStatus.filter(s => s).length;
            const freeFails = latencyHistory.freenetStatus.filter(s => s).length;
            const dirPct = Math.round(((totalReqs - dirFails) / totalReqs) * 100);
            const freePct = Math.round(((totalReqs - freeFails) / totalReqs) * 100);
            document.getElementById('directPctBig').textContent = dirPct + '%';
            document.getElementById('freenetPctBig').textContent = freePct + '%';
            latencyChart.data.datasets[0].label = 'Direct Access (Lat)';
            latencyChart.data.datasets[1].label = 'FreeNet Access (Lat)';
        }

        latencyChart.update();

        if (autoRefreshEnabled) {
            autoCheckTimer = setTimeout(() => startGraphForSite(currentGraphUrl, currentGraphName, true), 3000);
        }
    } catch (e) {
        console.error("Custom check fail:", e);
        if (autoRefreshEnabled && !autoCheckTimer) {
            autoCheckTimer = setTimeout(() => startGraphForSite(currentGraphUrl, currentGraphName, true), 3000);
        }
    }
}

function updateStats() {
    // Widgets removed, explicitly doing nothing
}

async function startChecks(mode) {
    const isVpn = mode === "freenet";
    if (isVpn && checkingFreenet) return;
    if (!isVpn && checkingDirect) return;
    
    if (isVpn) checkingFreenet = true; else checkingDirect = true;
    
    const btn = isVpn ? document.getElementById("btnVPN") : document.getElementById("btnDirect");
    if(btn) btn.disabled = true;
    const statusTextEl = document.getElementById("statusText");
    if (statusTextEl) statusTextEl.textContent = translations[currentLang].scanning;
    
    const progress = document.getElementById("progressBar");
    progress.style.width = "10%";

    // Run sites with a concurrency limit to prevent browser connection queue timeouts
    const concurrencyLimit = 5;
    let activePromises = [];
    
    for (let i = 0; i < allSites.length; i++) {
        const p = checkSite(allSites[i], isVpn).then(() => {
            const currentProgress = parseFloat(progress.style.width);
            if (currentProgress < 90) progress.style.width = (currentProgress + (80 / allSites.length)) + "%";
            activePromises.splice(activePromises.indexOf(p), 1);
        });
        activePromises.push(p);
        
        if (activePromises.length >= concurrencyLimit) {
            await Promise.race(activePromises);
        }
    }
    await Promise.all(activePromises);

    progress.style.width = "100%";
    setTimeout(() => {
        if (!checkingFreenet && !checkingDirect) progress.style.width = "0%";
    }, 1000);

    if (isVpn) checkingFreenet = false; else checkingDirect = false;
    
    if (!checkingFreenet && !checkingDirect) {
        const finalStatus = document.getElementById("statusText");
        if (finalStatus) finalStatus.textContent = translations[currentLang].standingBy;
        const pageTitle = document.getElementById("pageTitle");
        if (pageTitle) pageTitle.textContent = getTitleWithDate(translations[currentLang].title);
    }
    if (btn) btn.disabled = false;
}

function getTitleWithDate(base) {
    const now = new Date();
    const opts = { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' };
    return base + ' (' + now.toLocaleDateString('en-GB', opts) + ')';
}

    const langBtn = document.getElementById("langToggle");
    if(langBtn) langBtn.addEventListener("click", toggleLanguage);

buildGrid();

// Initial run: PER USER REQUEST: RUN SIMULTANEOUSLY
(async () => {
    // Fire both and let them run in parallel
    startChecks("freenet");
    startChecks("direct");
})();
</script>
</body>
</html>
