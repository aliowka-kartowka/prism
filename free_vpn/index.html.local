        freenet: "FreeNet",
        checking: "Checking...",
        online: "Online",
        offline: "Blocked",
        lang: "RU",
        searchTitle: "Quick Host Check",
        searchPlaceholder: "Enter hostname (e.g., example.com)...",
        searchBtn: "Check Now",
        resDirect: "Direct Access:",
        resVPN: "FreeNet Access:"
