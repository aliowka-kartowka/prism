<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FreeNet Monster - Connectivity Monitor</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="icon" type="image/png" href="assets/icon/app_icon.png">
    <style>
        :root {
            --bg-body: #0a0b10;
            --bg-card: #151921;
            --accent: #64ffda;
            --accent-glow: rgba(100, 255, 218, 0.3);
            --text-primary: #e6f1ff;
            --text-secondary: #8892b0;
            --success: #00ff7f;
            --error: #ff4d4d;
            --warning: #ffcc00;
            --font-main: "Outfit", sans-serif;
            --font-mono: "JetBrains Mono", monospace;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        body { 
            background: var(--bg-body); 
            color: var(--text-primary); 
            font-family: var(--font-main);
            min-height: 100vh;
            padding: 2rem;
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #233554;
        }

        .brand { display: flex; align-items: center; gap: 1rem; }
        .brand h1 { font-size: 1.8rem; font-weight: 600; letter-spacing: -0.5px; }
        .header-logo { width: 120px; height: 120px; border-radius: 50%; border: 2px solid var(--accent); }

        .controls { display: flex; gap: 1rem; align-items: center; }

        button {
            background: #112240;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 0.6rem 1.2rem;
            border-radius: 4px;
            cursor: pointer;
            font-family: var(--font-mono);
            font-size: 0.85rem;
            transition: all 0.2s ease;
            text-transform: uppercase;
        }

        button:hover:not(:disabled) {
            background: var(--accent-glow);
            box-shadow: 0 0 15px var(--accent-glow);
        }

        button:disabled { opacity: 0.5; cursor: not-allowed; border-color: var(--text-secondary); color: var(--text-secondary); }

        .lang-toggle {
            border-color: var(--text-secondary);
            color: var(--text-secondary);
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 1.5rem;
            border-radius: 8px;
            border-left: 4px solid var(--accent);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .stat-label { color: var(--text-secondary); font-size: 0.9rem; }
        .stat-value { font-size: 1.5rem; font-weight: 600; font-family: var(--font-mono); }
        .stat-value.success { color: var(--success); }
        .stat-value.error { color: var(--error); }

        /* Custom Host Check Section */
        .search-section {
            background: var(--bg-card);
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 3rem;
            border: 1px solid #233554;
        }

        .search-title {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .search-box {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .search-input {
            flex: 1;
            background: rgba(0,0,0,0.3);
            border: 1px solid #233554;
            border-radius: 6px;
            padding: 0.8rem 1.2rem;
            color: var(--text-primary);
            font-family: var(--font-mono);
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-input:focus { border-color: var(--accent); }

        .search-results {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .result-badge {
            background: rgba(0,0,0,0.2);
            padding: 1rem;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: var(--font-mono);
            font-size: 0.9rem;
        }

        .category-title {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin: 2rem 0 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 1.5rem;
            transition: transform 0.2s ease;
            border: 1px solid transparent;
        }

        .card:hover { border-color: #233554; transform: translateY(-3px); }

        .site-info { display: flex; align-items: center; justify-content: flex-start; gap: 0.8rem; margin-bottom: 1rem; }
        .site-name { font-weight: 600; font-size: 1.1rem; }
        .site-icon { width: 20px; height: 20px; color: var(--accent); }
        
        .status-badges { display: flex; flex-direction: column; gap: 0.5rem; }
        
        .badge {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-family: var(--font-mono);
            background: rgba(0,0,0,0.2);
        }

        .badge-status.online { color: var(--success); font-weight: 600; }
        .badge-status.offline { color: var(--error); font-weight: 600; }
        .badge-status.checking { color: var(--warning); }

        #progress-container {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: transparent;
            z-index: 1000;
        }
        #progressBar {
            height: 100%;
            width: 0%;
            background: var(--accent);
            box-shadow: 0 0 10px var(--accent);
            transition: width 0.3s ease;
        }

        .footer {
            margin-top: 4rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .search-results { grid-template-columns: 1fr; }
            .header { flex-direction: column; gap: 1rem; text-align: center; }
        }
    </style>
</head>
<body>

<div id="progress-container"><div id="progressBar"></div></div>

<div class="container">
    <header class="header">
        <div class="brand" style="display: flex; align-items: center; gap: 20px;">
            <img src="app_icon.png" alt="FreeNet Logo" class="header-logo">
            <div style="display: flex; flex-direction: column;">
                <h1 id="pageTitle" style="margin: 0;">Russian Internet Ban Monitoring</h1>
                <span style="color: #8892b0; font-size: 0.9rem; margin-top: 5px; font-family: 'Inter', sans-serif;">Powered by FreeNet Monster VPN</span>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 8px;">
            <div style="display: flex; gap: 10px;">
                <button id="btnTrial" onclick="requestTrial()" style="
                    background: transparent;
                    border: 1px solid #64ffda;
                    color: #64ffda;
                    font-weight: 600;
                    padding: 0.8rem 1.5rem;
                    border-radius: 8px;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    font-family: var(--font-mono);
                    font-size: 0.85rem;
                ">
                    <span id="txtTrial">GET FREE TRIAL</span>
                </button>
                <a href="https://t.me/FreeNetMonsterBot" target="_blank" style="text-decoration: none;">
                    <button id="btnSubscribe" style="
                        background: linear-gradient(135deg, #64ffda 0%, #48bb78 100%);
                        color: #0a192f;
                        font-weight: 700;
                        border: none;
                        padding: 0.8rem 1.5rem;
                        border-radius: 8px;
                        display: flex;
                        align-items: center;
                        gap: 10px;
                        box-shadow: 0 4px 15px rgba(100, 255, 218, 0.3);
                        animation: pulse 2s infinite;
                        letter-spacing: 0.5px;
                        cursor: pointer;
                    ">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                        <span id="txtSubscribe">GET SUBSCRIPTION</span>
                    </button>
                </a>
            </div>
            <div style="display: flex; justify-content: flex-end; align-items: center; gap: 15px;">
                <span style="font-size: 0.7rem; color: #8892b0; font-family: var(--font-mono);">via @FreeNetMonsterBot</span>
                <button id="langToggle" style="
                    background: rgba(100, 255, 218, 0.1);
                    border: 1px solid #64ffda;
                    color: #64ffda;
                    padding: 4px 10px;
                    border-radius: 4px;
                    cursor: pointer;
                    font-size: 0.75rem;
                    font-family: var(--font-mono);
                    font-weight: 600;
                ">RU</button>
            </div>
        </div>
    </header>

    <!-- Trial Modal -->
    <div id="trialModal" style="
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(10, 25, 47, 0.95);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(8px);
    ">
        <div style="
            background: #112240;
            padding: 2.5rem;
            border-radius: 16px;
            max-width: 500px;
            width: 90%;
            border: 1px solid #233554;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            text-align: center;
            position: relative;
        ">
            <button onclick="closeTrialModal()" style="
                position: absolute;
                top: 15px;
                right: 15px;
                background: none;
                border: none;
                color: #8892b0;
                font-size: 1.5rem;
                padding: 0;
                line-height: 1;
            ">&times;</button>
            <div style="color: #64ffda; margin-bottom: 1.5rem;">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M8 12l3 3 5-5"></path></svg>
            </div>
            <h2 id="modalTitle" style="color: #e6f1ff; margin-bottom: 0.5rem; font-family: 'Outfit';">Trial Created!</h2>
            <p id="modalSub" style="color: #8892b0; font-size: 0.9rem; margin-bottom: 1.5rem;">Your 1GB trial subscription is ready.</p>
            
            <div id="qrcodeCont" style="background: white; padding: 10px; border-radius: 8px; display: inline-block; margin-bottom: 1.5rem;">
                <img id="trialQR" src="" alt="QR Code" style="width: 150px; height: 150px; display: block;">
            </div>
            
            <div style="
                background: rgba(0,0,0,0.3);
                padding: 1rem;
                border-radius: 8px;
                border: 1px solid #233554;
                font-family: var(--font-mono);
                font-size: 0.8rem;
                color: #64ffda;
                word-break: break-all;
                margin-bottom: 1.5rem;
                text-align: left;
            " id="trialLink">---</div>
            
            <button onclick="copyTrialLink()" id="btnCopy" style="
                width: 100%;
                background: #64ffda;
                color: #0a192f;
                border: none;
                padding: 0.8rem;
                border-radius: 6px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 1.5rem;
                cursor: pointer;
            ">Copy Link</button>

            <div style="text-align: left; background: rgba(0,0,0,0.2); padding: 1.2rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid rgba(100,255,218,0.1);">
                <h4 id="howToUseTitle" style="color: #ccd6f6; margin: 0 0 10px 0; font-size: 0.9rem; font-family: 'Outfit';">How to use:</h4>
                <ul style="color: #8892b0; font-size: 0.8rem; padding-left: 1.2rem; margin: 0; line-height: 1.6; font-family: 'Inter';">
                    <li id="howToUseStep1">1. Copy the link above.</li>
                    <li id="howToUseStep2">2. Install a VPN client (v2rayNG, Streisand, or Shadowrocket).</li>
                    <li id="howToUseStep3">3. Add the link as a "Subscription" or "Import from Clipboard".</li>
                    <li id="howToUseStep4">4. Update the server list and connect.</li>
                </ul>
            </div>
            
            <p id="limitText" style="color: #8892b0; font-size: 0.75rem;">Limit: 1GB per user. Accounts expire after data usage.</p>
        </div>
    </div>

    <style>
        @keyframes pulse {
            0% { transform: scale(1); box-shadow: 0 4px 15px rgba(100, 255, 218, 0.3); }
            50% { transform: scale(1.05); box-shadow: 0 4px 25px rgba(100, 255, 218, 0.5); }
            100% { transform: scale(1); box-shadow: 0 4px 15px rgba(100, 255, 218, 0.3); }
        }
    </style>

    <div id="chartContainer" style="margin-bottom: 2rem; height: 260px; background: rgba(0,0,0,0.2); border-radius: 8px; padding: 1rem; border: 1px solid #233554; display: none; position: relative;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
            <h2 id="chartTitle" style="margin: 0; font-size: 1.1rem; color: #e6f1ff; font-family: 'Outfit';">Monitoring</h2>
            <div style="display: flex; gap: 20px; align-items: baseline; margin-right: 60px;">
                <div style="text-align: right;">
                    <span style="font-size: 0.7rem; color: rgba(255, 77, 77, 0.8); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">Direct</span>
                    <div id="directPctBig" style="font-size: 1.6rem; font-weight: 700; color: #ff4d4d; font-family: 'Outfit'; line-height: 1;">--%</div>
                </div>
                <div style="text-align: right;">
                    <span style="font-size: 0.7rem; color: rgba(100, 255, 218, 0.8); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">FreeNet</span>
                    <div id="freenetPctBig" style="font-size: 1.6rem; font-weight: 700; color: #64ffda; font-family: 'Outfit'; line-height: 1;">--%</div>
                </div>
            </div>
        </div>
        <div id="liveIndicator" style="position: absolute; top: 15px; right: 15px; color: var(--success); font-size: 0.7rem; font-family: var(--font-mono); display: flex; align-items: center; gap: 5px;">
            <span style="width: 6px; height: 6px; background: var(--success); border-radius: 50%; display: inline-block; animation: blink 1s infinite;"></span>
            LIVE
        </div>
        <div style="position: relative; height: 180px; width: 100%;">
            <canvas id="latencyChart"></canvas>
        </div>
    </div>
    <style>
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
    </style>

    <div id="monitorGrid"></div>


    <footer class="footer">
        <div style="margin-bottom: 10px; font-size: 0.95rem; color: #8892b0; font-family: 'Inter', sans-serif;">
            We ❤️ 🇺🇦<br>To support Ukraine visit <a href="https://u24.gov.ua/" target="_blank" style="color: #64ffda; text-decoration: none;">https://u24.gov.ua/</a>
        </div>
        &copy; 2026 FreeNet Monster Infrastructure
    </footer>
</div>

<script>
const translations = {
    en: {
        title: "Russian Internet Ban Monitoring",
        refreshDirect: "Refresh Direct",
        testFreenet: "Test with FreeNet",
        globalStatus: "Global Connectivity",
        directlyAccessible: "Directly Accessible From Russia",
        freenetWorking: "FreeNet Accessible",
        standingBy: "Standing by...",
        scanning: "Scanning...",
        direct: "Direct",
        freenet: "FreeNet",
        checking: "Checking...",
        online: "Online",
        offline: "Blocked",
        lang: "RU",
        searchTitle: "Quick Host Check",
        searchPlaceholder: "Enter hostname (e.g., example.com)...",
        searchBtn: "Check Now",
        resDirect: "Direct Access:",
        resVPN: "FreeNet Access:",
        subscribe: "GET SUBSCRIPTION",
        trial: "GET FREE TRIAL",
        modalTitle: "Trial Created!",
        modalSub: "Your 1GB trial subscription is ready.",
        btnCopy: "Copy Link",
        btnCopied: "Copied!",
        limitText: "Limit: 1GB per user. Accounts expire after data usage.",
        howToUseTitle: "How to use:",
        howToUseStep1: "1. Copy the link above.",
        howToUseStep2: "2. Install a VPN client (v2rayNG, Streisand, or Shadowrocket).",
        howToUseStep3: "3. Add the link as a 'Subscription' or 'Import from Clipboard'.",
        howToUseStep4: "4. Update the server list and connect."
    },
    ru: {
        title: "Russian Internet Ban Monitoring",
        refreshDirect: "Обновить (Прямое)",
        testFreenet: "Тест через FreeNet",
        globalStatus: "Состояние подключения",
        directlyAccessible: "Доступно из России",
        freenetWorking: "Доступно через FreeNet",
        standingBy: "Ожидание...",
        scanning: "Сканирование...",
        direct: "Прямое",
        freenet: "FreeNet",
        checking: "Проверка...",
        online: "Доступен",
        offline: "Заблокирован",
        lang: "EN",
        searchTitle: "Быстрая проверка",
        searchPlaceholder: "Введите адрес (например, google.com)...",
        searchBtn: "Проверить",
        resDirect: "Прямой доступ:",
        resVPN: "Через FreeNet:",
        subscribe: "ПОДПИСКА VPN",
        trial: "ПРОБНЫЙ ПЕРИОД",
        modalTitle: "Доступ создан!",
        modalSub: "Ваша подписка на 1ГБ готова.",
        btnCopy: "Копировать",
        btnCopied: "Скопировано!",
        limitText: "Лимит: 1ГБ на пользователя. Аккаунт отключится после исчерпания трафика.",
        howToUseTitle: "Как использовать:",
        howToUseStep1: "1. Скопируйте ссылку выше.",
        howToUseStep2: "2. Установите VPN-клиент (v2rayNG, Streisand или Shadowrocket).",
        howToUseStep3: "3. Добавьте ссылку как «Подписку» или «Импорт из буфера обмена».",
        howToUseStep4: "4. Обновите список серверов и подключитесь."
    }
};

let currentLang = "en";

const siteCategories = {
    "Sites": [
        { name: "Youtube", url: "https://youtube.com", icon: "tv" },
        { name: "Telegram", url: "https://t.me", icon: "users" },
        { name: "Instagram", url: "https://instagram.com", icon: "users" },
        { name: "Facebook", url: "https://facebook.com", icon: "users" },
        { name: "Whatsapp", url: "https://whatsapp.com", icon: "globe" },
        { name: "Google", url: "https://google.com", icon: "search" },
        { name: "Linkedin", url: "https://linkedin.com", icon: "users" },
        { name: "Netflix", url: "https://netflix.com", icon: "tv" },
        { name: "Aliexpress", url: "https://aliexpress.com", icon: "shopping-cart" },
        { name: "Bbc", url: "https://bbc.com", icon: "file-text" },
        { name: "Foxnews", url: "https://foxnews.com", icon: "file-text" },
        { name: "Chatgpt", url: "https://chatgpt.com", icon: "cpu" },
        { name: "Xvideos", url: "https://xvideos.com", icon: "alert-triangle" },
        { name: "Pornhub", url: "https://pornhub.com", icon: "alert-triangle" },
        { name: "Xnxx", url: "https://xnxx.com", icon: "alert-triangle" },
        { name: "Youport", url: "https://www.youporn.com", icon: "heart" }
    ]
};

const allSites = Object.values(siteCategories).flat();
let checkingFreenet = false;
let checkingDirect = false;
let autoRefreshEnabled = true;
let autoCheckTimer = null;
let currentGraphUrl = null;
let currentGraphName = null;

let latencyChart = null;
const latencyHistory = {
    labels: [],
    direct: [],
    directStatus: [],
    freenet: [],
    freenetStatus: []
};

function initLatencyChart() {
    const ctx = document.getElementById('latencyChart').getContext('2d');
    latencyChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: latencyHistory.labels,
            datasets: [
                {
                    label: 'Direct Access (ms)',
                    data: latencyHistory.direct,
                    borderColor: '#ff4d4d',
                    backgroundColor: 'rgba(255, 77, 77, 0.1)',
                    borderWidth: 2,
                    tension: 0.3,
                    fill: false,
                    pointBackgroundColor: '#ff4d4d',
                    pointStyle: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 'crossRot' : 'circle'),
                    pointRadius: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 8 : 4),
                    pointHoverRadius: (ctx) => (latencyHistory.directStatus[ctx.dataIndex] ? 10 : 6),
                    segment: {
                        borderColor: ctx => latencyHistory.directStatus[ctx.p1DataIndex] || latencyHistory.directStatus[ctx.p0DataIndex] ? 'rgba(255, 77, 77, 0.5)' : undefined,
                        borderDash: ctx => latencyHistory.directStatus[ctx.p1DataIndex] || latencyHistory.directStatus[ctx.p0DataIndex] ? [5, 5] : undefined,
                    }
                },
                {
                    label: 'FreeNet Access (ms)',
                    data: latencyHistory.freenet,
                    borderColor: '#64ffda',
                    backgroundColor: 'rgba(100, 255, 218, 0.1)',
                    borderWidth: 3,
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: '#64ffda',
                    pointStyle: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 'crossRot' : 'circle'),
                    pointRadius: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 8 : 4),
                    pointHoverRadius: (ctx) => (latencyHistory.freenetStatus[ctx.dataIndex] ? 10 : 6),
                    segment: {
                        borderDash: ctx => latencyHistory.freenetStatus[ctx.p1DataIndex] || latencyHistory.freenetStatus[ctx.p0DataIndex] ? [5, 5] : undefined,
                    }
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            scales: {
                x: {
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: '#8892b0', font: { family: 'JetBrains Mono', size: 10 } }
                },
                y: {
                    grid: { color: 'rgba(255,255,255,0.05)' },
                    ticks: { color: '#8892b0', font: { family: 'JetBrains Mono', size: 10 } },
                    beginAtZero: true,
                    title: { display: true, text: 'Latency (ms)', color: '#8892b0', font: { family: 'Outfit' } }
                }
            },
            plugins: {
                legend: {
                    display: false,
                    position: 'top',
                    labels: { color: '#e6f1ff', font: { family: 'Outfit', size: 12 }, usePointStyle: true }
                },
                tooltip: {
                    backgroundColor: '#112240',
                    titleColor: '#64ffda',
                    bodyColor: '#e6f1ff',
                    borderColor: '#233554',
                    borderWidth: 1,
                    padding: 12,
                    titleFont: { family: 'Outfit', weight: 'bold', size: 14 },
                    bodyFont: { family: 'JetBrains Mono' },
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            const isFreenet = label.includes('FreeNet');
                            const isBlocked = isFreenet ? latencyHistory.freenetStatus[context.dataIndex] : latencyHistory.directStatus[context.dataIndex];
                            if (label) label += ': ';
                            if (isBlocked) {
                                return label + '❌ BLOCKED';
                            }
                            return label + context.raw + 'ms';
                        }
                    }
                }
            }
        }
    });
}

function toggleLanguage() {
    currentLang = currentLang === "en" ? "ru" : "en";
    const t = translations[currentLang];
    
    document.getElementById("pageTitle").textContent = getTitleWithDate(t.title);
    document.getElementById("btnDirect").textContent = t.refreshDirect;
    document.getElementById("btnVPN").textContent = t.testFreenet;
    document.getElementById("langToggle").textContent = t.lang;
    document.getElementById("lblGlobalStatus").textContent = t.globalStatus;
    document.getElementById("lblAccessible").textContent = t.directlyAccessible;
    document.getElementById("lblFreenetReady").textContent = t.freenetWorking;
    
    // Search elements
    document.getElementById("lblSearchTitle").innerHTML = '<i data-lucide="search" style="width: 18px; margin-top: -2px"></i> ' + t.searchTitle;
    document.getElementById("customUrl").placeholder = t.searchPlaceholder;
    document.getElementById("btnCustom").textContent = t.searchBtn;
    document.getElementById("lblResDirect").textContent = t.resDirect;
    document.getElementById("lblResVPN").textContent = t.resVPN;
    document.getElementById('txtSubscribe').textContent = t.subscribe;
    const qrHint = document.getElementById("qrHint");
    if (qrHint) qrHint.textContent = currentLang === "ru" ? "Сканируйте или сделайте скриншот" : "Scan or Screenshot to Import";

    const cdVal = document.getElementById("customDirectVal");
    if (cvVal.getAttribute("data-status")) updateBadgeText(cvVal, cvVal.getAttribute("data-status"), t);
    
    // Updated Trial Modal text
    const mTitle = document.getElementById("modalTitle");
    const mSub = document.getElementById("modalSub");
    const bCopy = document.getElementById("btnCopy");
    const lText = document.getElementById("limitText");
    const hTitle = document.getElementById("howToUseTitle");
    const hStep1 = document.getElementById("howToUseStep1");
    const hStep2 = document.getElementById("howToUseStep2");
    const hStep3 = document.getElementById("howToUseStep3");
    const hStep4 = document.getElementById("howToUseStep4");

    if (mTitle) mTitle.textContent = t.modalTitle;
    if (mSub) mSub.textContent = t.modalSub;
    if (bCopy) bCopy.textContent = t.btnCopy;
    if (lText) lText.textContent = t.limitText;
    if (hTitle) hTitle.textContent = t.howToUseTitle;
    if (hStep1) hStep1.textContent = t.howToUseStep1;
    if (hStep2) hStep2.textContent = t.howToUseStep2;
    if (hStep3) hStep3.textContent = t.howToUseStep3;
    if (hStep4) hStep4.textContent = t.howToUseStep4;
    
    const txtTrial = document.getElementById('txtTrial');
    if (txtTrial) txtTrial.textContent = t.trial;

    allSites.forEach(s => {
        const id = s.name.replace(/[^a-z0-9]/gi, "_");
        const db = document.getElementById(id + "_direct_val");
        const vb = document.getElementById(id + "_vpn_val");
        const dl = document.getElementById(id + "_direct_label");
        const vl = document.getElementById(id + "_vpn_label");
        
        if (dl) dl.textContent = t.direct + ":";
        if (vl) vl.textContent = t.freenet + ":";
        
        if (db) {
            const status = db.getAttribute("data-status");
            if (db.classList.contains("checking")) db.textContent = t.checking;
            else if (status !== null) updateBadgeText(db, status, t);
        }
        
        if (vb) {
            const status = vb.getAttribute("data-status");
            if (vb.classList.contains("checking")) vb.textContent = t.checking;
            else if (status !== null) updateBadgeText(vb, status, t);
        }
    });
    lucide.createIcons();
}

function updateBadgeText(el, status, t) {
    if (status === "1") {
        el.textContent = t.online;
        el.className = "badge-status online";
    } else if (status === "0") {
        el.textContent = t.offline;
        el.className = "badge-status offline";
    } else {
        el.textContent = "—";
        el.className = "badge-status";
    }
}

function getFavicon(site) {
    if (site.name === "WhatsApp") return "https://static.whatsapp.net/rsrc.php/v3/yP/r/r_oBsbi9V90.png";
    try {
        return "https://www.google.com/s2/favicons?sz=64&domain=" + new URL(site.url).hostname;
    } catch (e) {
        return "";
    }
}

function buildGrid() {
    const container = document.getElementById("monitorGrid");
    container.innerHTML = "";
    const t = translations[currentLang];

    for (const [cat, sites] of Object.entries(siteCategories)) {
        const grid = document.createElement("div");
        grid.className = "grid";
        
        sites.forEach(site => {
            const id = site.name.replace(/[^a-z0-9]/gi, "_");
            const faviconUrl = getFavicon(site);
            const card = document.createElement("div");
            card.className = "card";
            card.style.cursor = "pointer";
            card.onclick = () => { startGraphForSite(site.url, site.name); };
            card.innerHTML = 
                "<div class=\"site-info\">" +
                    "<img src=\"" + faviconUrl + "\" class=\"site-icon\" onerror=\"this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2224%22 height=%2224%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364ffda%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><circle cx=%2212%22 cy=%2212%22 r=%2210%22></circle><line x1=%222%22 y1=%2212%22 x2=%2222%22 y2=%2212%22></line><path d=%22M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z%22></path></svg>'\">" +
                    "<span class=\"site-name\">" + site.name + "</span>" +
                "</div>" +
                "<div class=\"status-badges\">" +
                    "<div class=\"badge\" id=\"" + id + "_vpn_badge\">" +
                        "<span id=\"" + id + "_vpn_label\">" + t.freenet + ":</span>" +
                        "<span id=\"" + id + "_vpn_val\" class=\"badge-status\">—</span>" +
                    "</div>" +
                    "<div class=\"badge\" id=\"" + id + "_direct_badge\">" +
                        "<span id=\"" + id + "_direct_label\">" + t.direct + ":</span>" +
                        "<span id=\"" + id + "_direct_val\" class=\"badge-status\">—</span>" +
                    "</div>" +
                "</div>";
            grid.appendChild(card);
        });
        container.appendChild(grid);
    }
    if (typeof lucide !== 'undefined') lucide.createIcons();
}

async function fetchWithTimeout(resource, options = {}) {
    const { timeout = 3000 } = options;
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeout);
    try {
        const response = await fetch(resource, { ...options, signal: controller.signal });
        clearTimeout(id);
        return response;
    } catch (e) {
        clearTimeout(id);
        throw e;
    }
}

async function checkSite(site, useVpn) {
    const id = site.name.replace(/[^a-z0-9]/gi, "_");
    const suffix = useVpn ? "_vpn" : "_direct";
    const valEl = document.getElementById(id + suffix + "_val");
    const t = translations[currentLang];

    valEl.textContent = t.checking;
    valEl.className = "badge-status checking";

    let finalStatus = "0";
    const maxAttempts = 3;

    for (let i = 0; i < maxAttempts; i++) {
        try {
            const res = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(site.url) + "&use_vpn=" + useVpn);
            const data = await res.json();
            const status = data.status === "down" ? "0" : "1";
            finalStatus = status;
            if (status === "1") break;
        } catch (e) {
            finalStatus = "0";
        }
        // If it was the last attempt, don't wait obviously
        if (i < maxAttempts - 1 && finalStatus === "0") {
            await new Promise(r => setTimeout(r, 500));
        }
    }

    valEl.setAttribute("data-status", finalStatus);
    updateBadgeText(valEl, finalStatus, t);
    updateStats();
}
async function startGraphForSite(url, name, isAuto = false) {
    if (!url) return;
    
    if (autoCheckTimer) clearTimeout(autoCheckTimer);

    if (!isAuto) {
        currentGraphUrl = url;
        currentGraphName = name;
        latencyHistory.labels = [];
        latencyHistory.direct = [];
        latencyHistory.directStatus = [];
        latencyHistory.freenet = [];
        latencyHistory.freenetStatus = [];
        if (latencyChart) {
            latencyChart.destroy();
            latencyChart = null;
        }
        document.getElementById('directPctBig').textContent = '--%';
        document.getElementById('freenetPctBig').textContent = '--%';
        
        const titleEl = document.getElementById('chartTitle');
        if(titleEl) titleEl.textContent = `Monitoring: ${name}`;
        
        const chartCont = document.getElementById('chartContainer');
        if(chartCont) chartCont.style.display = 'block';
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    try {
        const startTotal = Date.now();
        await Promise.all([
            (async () => {
                const s = Date.now();
                try {
                    const resV = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(url) + "&use_vpn=true");
                    const dataV = await resV.json();
                    const lat = Date.now() - s;
                    const statusV = dataV.status === "down" ? "0" : "1";
                    latencyHistory.freenet.push(lat);
                    latencyHistory.freenetStatus.push(statusV === "0");
                } catch (e) {
                    latencyHistory.freenet.push(3000); 
                    latencyHistory.freenetStatus.push(true);
                }
            })(),
            (async () => {
                const s = Date.now();
                try {
                    const resD = await fetchWithTimeout("/api/check?url=" + encodeURIComponent(url) + "&use_vpn=false");
                    const dataD = await resD.json();
                    const lat = Date.now() - s;
                    const statusD = dataD.status === "down" ? "0" : "1";
                    latencyHistory.direct.push(lat);
                    latencyHistory.directStatus.push(statusD === "0");
                } catch (e) {
                    latencyHistory.direct.push(3000);
                    latencyHistory.directStatus.push(true);
                }
            })()
        ]);

        const host = new URL(url).hostname;
        latencyHistory.labels.push(new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'}));
        
        const MAX_SAMPLES = 20;
        if (latencyHistory.labels.length > MAX_SAMPLES) {
            latencyHistory.labels.shift();
            latencyHistory.direct.shift();
            latencyHistory.directStatus.shift();
            latencyHistory.freenet.shift();
            latencyHistory.freenetStatus.shift();
        }
        
        if (!latencyChart) {
            initLatencyChart();
        }

        const totalReqs = latencyHistory.labels.length;
        if (totalReqs > 0) {
            const dirFails = latencyHistory.directStatus.filter(s => s).length;
            const freeFails = latencyHistory.freenetStatus.filter(s => s).length;
            const dirPct = Math.round(((totalReqs - dirFails) / totalReqs) * 100);
            const freePct = Math.round(((totalReqs - freeFails) / totalReqs) * 100);
            document.getElementById('directPctBig').textContent = dirPct + '%';
            document.getElementById('freenetPctBig').textContent = freePct + '%';
            latencyChart.data.datasets[0].label = 'Direct Access';
            latencyChart.data.datasets[1].label = 'FreeNet Access';
        }

        latencyChart.update();

        if (autoRefreshEnabled) {
            autoCheckTimer = setTimeout(() => startGraphForSite(currentGraphUrl, currentGraphName, true), 3000);
        }
    } catch (e) {
        console.error("Custom check fail:", e);
        if (autoRefreshEnabled && !autoCheckTimer) {
            autoCheckTimer = setTimeout(() => startGraphForSite(currentGraphUrl, currentGraphName, true), 3000);
        }
    }
}

function updateStats() {
    // Widgets removed, explicitly doing nothing
}

async function startChecks(mode) {
    const isVpn = mode === "freenet";
    if (isVpn && checkingFreenet) return;
    if (!isVpn && checkingDirect) return;
    
    if (isVpn) checkingFreenet = true; else checkingDirect = true;
    
    const btn = isVpn ? document.getElementById("btnVPN") : document.getElementById("btnDirect");
    if(btn) btn.disabled = true;
    const statusTextEl = document.getElementById("statusText");
    if (statusTextEl) statusTextEl.textContent = translations[currentLang].scanning;
    
    const progress = document.getElementById("progressBar");
    progress.style.width = "10%";

    // Run sites with a concurrency limit to prevent browser connection queue timeouts
    const concurrencyLimit = 3;
    let activePromises = [];
    
    for (let i = 0; i < allSites.length; i++) {
        const p = checkSite(allSites[i], isVpn).then(() => {
            const currentProgress = parseFloat(progress.style.width);
            if (currentProgress < 90) progress.style.width = (currentProgress + (80 / allSites.length)) + "%";
            activePromises.splice(activePromises.indexOf(p), 1);
        });
        activePromises.push(p);
        
        if (activePromises.length >= concurrencyLimit) {
            await Promise.race(activePromises);
        }
    }
    await Promise.all(activePromises);

    progress.style.width = "100%";
    setTimeout(() => {
        if (!checkingFreenet && !checkingDirect) progress.style.width = "0%";
    }, 1000);

    if (isVpn) checkingFreenet = false; else checkingDirect = false;
    
    if (!checkingFreenet && !checkingDirect) {
        const finalStatus = document.getElementById("statusText");
        if (finalStatus) finalStatus.textContent = translations[currentLang].standingBy;
        const pageTitle = document.getElementById("pageTitle");
        if (pageTitle) pageTitle.textContent = getTitleWithDate(translations[currentLang].title);
    }
    if (btn) btn.disabled = false;
}

function getTitleWithDate(base) {
    const now = new Date();
    const opts = { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' };
    return base + ' (' + now.toLocaleDateString('en-GB', opts) + ')';
}

    const langBtn = document.getElementById("langToggle");
    if(langBtn) langBtn.addEventListener("click", toggleLanguage);

buildGrid();

// Initial run: PER USER REQUEST: RUN SIMULTANEOUSLY
(async () => {
    // Fire both and let them run in parallel
    startChecks("freenet");
    startChecks("direct");
})();
async function requestTrial() {
    const btn = document.getElementById('btnTrial');
    const originalText = document.getElementById('txtTrial').textContent;
    
    btn.disabled = true;
    document.getElementById('txtTrial').textContent = "...";
    
    try {
        const resp = await fetch('/api/trial');
        const data = await resp.json();
        
        if (data.subscription_url) {
            // Use the first direct proxy link (vless://) for the QR code as requested for better app compatibility (like V2Box)
            const qrContent = (data.links && data.links.length > 0) ? data.links[0] : data.subscription_url;
            const encodedUrl = encodeURIComponent(qrContent);
            document.getElementById('trialQR').src = `https://api.qrserver.com/v1/create-qr-code/?size=400x400&data=${encodedUrl}&margin=5&bgcolor=ffffff`;
            
            document.getElementById('trialLink').textContent = data.subscription_url;
            document.getElementById('trialModal').style.display = 'flex';
        } else {
            alert(data.error || "Failed to create trial.");
        }
    } catch (e) {
        alert("Server error. Please try again later.");
    } finally {
        btn.disabled = false;
        document.getElementById('txtTrial').textContent = originalText;
    }
}

function closeTrialModal() {
    document.getElementById('trialModal').style.display = 'none';
}

function copyTrialLink() {
    const link = document.getElementById('trialLink').textContent;
    navigator.clipboard.writeText(link).then(() => {
        const btn = document.getElementById('btnCopy');
        const originalText = btn.textContent;
        const t = translations[currentLang];
        btn.textContent = t.btnCopied;
        btn.style.background = "#48bb78";
        setTimeout(() => {
            btn.textContent = t.btnCopy;
            btn.style.background = "#64ffda";
        }, 2000);
    });
}
</script>
