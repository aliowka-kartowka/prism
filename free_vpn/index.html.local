    ru: {
        title: "FreeNet Monitor",
        refreshDirect: "Обновить (Прямое)",
        testFreenet: "Тест через FreeNet",
        globalStatus: "Состояние подключения",
        directlyAccessible: "Доступно из России",
        freenetWorking: "Доступно через FreeNet",
        standingBy: "Ожидание...",
        scanning: "Сканирование...",
        direct: "Прямое",
        freenet: "FreeNet",
        checking: "Проверка...",
        online: "Доступен",
        offline: "Заблокирован",
        lang: "EN",
        searchTitle: "Быстрая проверка",
        searchPlaceholder: "Введите адрес (например, google.com)...",
        searchBtn: "Проверить",
        resDirect: "Прямой доступ:",
        resVPN: "Через FreeNet:"
    }
};

let currentLang = "en";

const siteCategories = {
    "Social & Video": [
