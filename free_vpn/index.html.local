<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FreeNet Monster - Connectivity Monitor</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="icon" type="image/png" href="assets/icon/app_icon.png">
    <style>
        :root {
            --bg-body: #0a0b10;
            --bg-card: #151921;
            --accent: #64ffda;
            --accent-glow: rgba(100, 255, 218, 0.3);
            --text-primary: #e6f1ff;
            --text-secondary: #8892b0;
            --success: #00ff7f;
            --error: #ff4d4d;
            --warning: #ffcc00;
            --font-main: "Outfit", sans-serif;
            --font-mono: "JetBrains Mono", monospace;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        body { 
            background: var(--bg-body); 
            color: var(--text-primary); 
            font-family: var(--font-main);
            min-height: 100vh;
            padding: 2rem;
            line-height: 1.6;
        }

        .container { max-width: 1200px; margin: 0 auto; }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #233554;
        }

        .brand { display: flex; align-items: center; gap: 1rem; }
        .brand h1 { font-size: 1.8rem; font-weight: 600; letter-spacing: -0.5px; }
        .header-logo { width: 120px; height: 120px; border-radius: 50%; border: 2px solid var(--accent); }

        .controls { display: flex; gap: 1rem; align-items: center; }

        button {
            background: #112240;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 0.6rem 1.2rem;
            border-radius: 4px;
            cursor: pointer;
            font-family: var(--font-mono);
            font-size: 0.85rem;
            transition: all 0.2s ease;
            text-transform: uppercase;
        }

        button:hover:not(:disabled) {
            background: var(--accent-glow);
            box-shadow: 0 0 15px var(--accent-glow);
        }

        button:disabled { opacity: 0.5; cursor: not-allowed; border-color: var(--text-secondary); color: var(--text-secondary); }

        .lang-toggle {
            border-color: var(--text-secondary);
            color: var(--text-secondary);
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 1.5rem;
            border-radius: 8px;
            border-left: 4px solid var(--accent);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .stat-label { color: var(--text-secondary); font-size: 0.9rem; }
        .stat-value { font-size: 1.5rem; font-weight: 600; font-family: var(--font-mono); }
        .stat-value.success { color: var(--success); }
        .stat-value.error { color: var(--error); }

        /* Custom Host Check Section */
        .search-section {
            background: var(--bg-card);
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 3rem;
            border: 1px solid #233554;
        }

        .search-title {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .search-box {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .search-input {
            flex: 1;
            background: rgba(0,0,0,0.3);
            border: 1px solid #233554;
            border-radius: 6px;
            padding: 0.8rem 1.2rem;
            color: var(--text-primary);
            font-family: var(--font-mono);
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-input:focus { border-color: var(--accent); }

        .search-results {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .result-badge {
            background: rgba(0,0,0,0.2);
            padding: 1rem;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: var(--font-mono);
            font-size: 0.9rem;
        }

        .category-title {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin: 2rem 0 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 1.5rem;
            transition: transform 0.2s ease;
            border: 1px solid transparent;
        }

        .card:hover { border-color: #233554; transform: translateY(-3px); }

        .site-info { display: flex; align-items: center; justify-content: flex-start; gap: 0.8rem; margin-bottom: 1rem; }
        .site-name { font-weight: 600; font-size: 1.1rem; }
        .site-icon { width: 20px; height: 20px; color: var(--accent); }
        
        .status-badges { display: flex; flex-direction: column; gap: 0.5rem; }
        
        .badge {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-family: var(--font-mono);
            background: rgba(0,0,0,0.2);
        }

        .badge-status.online { color: var(--success); font-weight: 600; }
        .badge-status.offline { color: var(--error); font-weight: 600; }
        .badge-status.checking { color: var(--warning); }

        #progress-container {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: transparent;
            z-index: 1000;
        }
        #progressBar {
            height: 100%;
            width: 0%;
            background: var(--accent);
            box-shadow: 0 0 10px var(--accent);
            transition: width 0.3s ease;
        }

        .footer {
            margin-top: 4rem;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .search-results { grid-template-columns: 1fr; }
            .header { flex-direction: column; gap: 1rem; text-align: center; }
        }
    </style>
</head>
<body>

<div id="progress-container"><div id="progressBar"></div></div>

<div class="container">
    <header class="header">
        <div class="brand" style="display: flex; align-items: center; gap: 20px;">
            <img src="assets/icon/app_icon.png" alt="FreeNet Logo" class="header-logo">
            <div style="display: flex; flex-direction: column;">
                <h1 id="pageTitle" style="margin: 0;">FreeNet Monitor</h1>
                <span style="color: #8892b0; font-size: 0.9rem; margin-top: 5px; font-family: 'Inter', sans-serif;">Russian Internet monitoring with / without Freenet VPN</span>
            </div>
        </div>

    </header>

    <div id="chartContainer" style="margin-bottom: 2rem; height: 260px; background: rgba(0,0,0,0.2); border-radius: 8px; padding: 1rem; border: 1px solid #233554; display: none; position: relative;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
            <h2 id="chartTitle" style="margin: 0; font-size: 1.1rem; color: #e6f1ff; font-family: 'Outfit';">Monitoring</h2>
            <div style="display: flex; gap: 20px; align-items: baseline; margin-right: 60px;">
                <div style="text-align: right;">
                    <span style="font-size: 0.7rem; color: rgba(255, 77, 77, 0.8); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">Direct</span>
                    <div id="directPctBig" style="font-size: 1.6rem; font-weight: 700; color: #ff4d4d; font-family: 'Outfit'; line-height: 1;">--%</div>
                </div>
                <div style="text-align: right;">
                    <span style="font-size: 0.7rem; color: rgba(100, 255, 218, 0.8); text-transform: uppercase; font-weight: 600; letter-spacing: 1px;">FreeNet</span>
                    <div id="freenetPctBig" style="font-size: 1.6rem; font-weight: 700; color: #64ffda; font-family: 'Outfit'; line-height: 1;">--%</div>
                </div>
            </div>
        </div>
        <div id="liveIndicator" style="position: absolute; top: 15px; right: 15px; color: var(--success); font-size: 0.7rem; font-family: var(--font-mono); display: flex; align-items: center; gap: 5px;">
            <span style="width: 6px; height: 6px; background: var(--success); border-radius: 50%; display: inline-block; animation: blink 1s infinite;"></span>
            LIVE
        </div>
        <div style="position: relative; height: 180px; width: 100%;">
            <canvas id="latencyChart"></canvas>
        </div>
    </div>
    <style>
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
    </style>

    <div id="monitorGrid"></div>


    <footer class="footer">
        &copy; 2026 FreeNet Monster Infrastructure
    </footer>
</div>

<script>
const translations = {
